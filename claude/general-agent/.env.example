# General Agent 环境配置示例
# 复制此文件为 .env 并修改配置

# ================================
# LLM 配置
# ================================

# 是否使用 Ollama 本地模型（true/false）
# false: 使用 Mock 客户端（仅用于测试）
# true: 使用 Ollama 本地模型
USE_OLLAMA=true

# Ollama 服务器地址
# 默认: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Ollama 模型名称
# 常用模型:
#   - llama3.2:latest (推荐，约2GB)
#   - llama3.2:3b (3B参数，约2GB)
#   - llama3.2:1b (1B参数，约1GB)
#   - llama3.1:8b (8B参数，约4.7GB)
#   - qwen2.5:latest (通义千问，约4.7GB)
#   - gemma2:2b (Google Gemma 2B，约1.6GB)
OLLAMA_MODEL=qwen3.5:latest

# 温度参数（0.0-1.0）
# 较低值: 更确定性和专注的回答
# 较高值: 更随机和创造性的回答
# 推荐: 0.7
OLLAMA_TEMPERATURE=0.7

# ================================
# 数据库配置
# ================================

# SQLite 数据库路径
DATABASE_PATH=data/general_agent.db

# ================================
# 服务器配置
# ================================

# 服务器端口
PORT=8000

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO
